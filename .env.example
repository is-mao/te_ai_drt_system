# ===========================================
# DRT System Environment Configuration
# ===========================================

# --- Database ---
# Default: sqlite (no setup needed)
DRT_DB_TYPE=sqlite

# --- App Settings ---
# FLASK_DEBUG=1 for development, 0 for production
FLASK_DEBUG=1

# Secret key (set manually for production)
# DRT_SECRET_KEY=your-random-secret-key

# --- Google Gemini AI ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- CIRCUIT API (Cisco Enterprise AI) ---
CIRCUIT_API_ENDPOINT=https://chat-ai.cisco.com/openai/deployments/gemini-3.1-flash-lite/chat/completions?api-version=2025-04-01-preview
CIRCUIT_APP_KEY=your_circuit_app_key_here
CIRCUIT_ACCESS_TOKEN=your_circuit_access_token_here
CIRCUIT_MODEL=gemini-3.1-flash-lite

# --- Database Sync (SFTP) ---
DRT_SYNC_SSH_HOST=10.69.230.185
DRT_SYNC_SSH_PORT=36021
DRT_SYNC_SSH_USER=root
DRT_SYNC_SSH_PASSWORD=your_ssh_password_here
