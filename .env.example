# ===========================================
# DRT System Environment Configuration
# ===========================================

# --- Database ---
# Priority: DATABASE_URL > DRT_DB_TYPE
# Render/cloud platforms set DATABASE_URL automatically

# Local: use 'sqlite' (no setup) or 'mysql'
DRT_DB_TYPE=sqlite

# MySQL settings (only if DRT_DB_TYPE=mysql)
DRT_MYSQL_HOST=localhost
DRT_MYSQL_PORT=3306
DRT_MYSQL_USER=root
DRT_MYSQL_PASSWORD=your_password_here
DRT_MYSQL_DB=ai_drt_system

# PostgreSQL settings (only if DRT_DB_TYPE=postgresql)
# DRT_PG_HOST=localhost
# DRT_PG_PORT=5432
# DRT_PG_USER=postgres
# DRT_PG_PASSWORD=your_password_here
# DRT_PG_DB=ai_drt_system

# Cloud: set DATABASE_URL directly (Render auto-provides this)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- App Settings ---
# FLASK_DEBUG=1 for development, 0 for production
FLASK_DEBUG=1

# Secret key (auto-generated on Render, set manually for local)
# DRT_SECRET_KEY=your-random-secret-key

# --- Google Gemini AI ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
